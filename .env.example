# Multi-Agent SQL Optimization Framework Environment Configuration

# =============================================================================
# GROQ API Configuration
# =============================================================================
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# Application Configuration
# =============================================================================
# Application environment (development, production, testing)
APP_ENV=development

# Server configuration
HOST=0.0.0.0
PORT=8000

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/optimizer.log

# =============================================================================
# Database Configuration
# =============================================================================
# DuckDB configuration (if needed for future extensions)
DUCKDB_MEMORY_LIMIT=1GB
DUCKDB_THREADS=4

# =============================================================================
# Performance Configuration
# =============================================================================
# Maximum optimization candidates to generate
MAX_OPTIMIZATION_CANDIDATES=5

# API timeout in seconds
API_TIMEOUT_SECONDS=180

# =============================================================================
# Security Configuration
# =============================================================================
# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Development Configuration
# =============================================================================
# Enable debug mode
DEBUG=false

# Enable auto-reload in development
AUTO_RELOAD=true

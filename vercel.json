{
  "version": 2,
  "builds": [
    {
      "src": "src/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/optimize-sql.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/optimize-sql",
      "dest": "/api/optimize-sql.py"
    },
    {
      "src": "/(.*)",
      "dest": "/src/$1"
    }
  ]
}
